# Database
DATABASE_URL="postgresql://raffle:raffle_secret@localhost:5432/raffle_db?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET="change-me-access-secret-in-production"
JWT_REFRESH_SECRET="change-me-refresh-secret-in-production"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
API_URL="http://localhost:3001"

# Stripe
STRIPE_SECRET_KEY="sk_test_your_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Email (optional)
EMAIL_FROM="noreply@footballclub.example"
SENDGRID_API_KEY=""

# S3 / MinIO
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="raffle-backups"
