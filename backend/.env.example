# =============================================================================
# Football Club Raffle API — Backend environment
# Copy to backend/.env and fill in the values.
# =============================================================================

NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# --- Firebase Admin (REQUIRED: Firestore + Auth) ----------------------------
# From Firebase Console > Project settings > Service accounts > Generate new private key.
# Paste the values from the downloaded JSON. Keep the private key on ONE line with \n.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Alternative to the three vars above: absolute path to the service-account JSON file.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccount.json

# --- Admin access -----------------------------------------------------------
# Comma-separated Google emails that are auto-promoted to super_admin on login.
ADMIN_EMAILS=

# --- Club settings ----------------------------------------------------------
CLUB_NAME=Football Club

# --- Wallet security --------------------------------------------------------
# Secret used to HMAC-sign wallet ledger entries (tamper-evidence). Use a long
# random string in production. If omitted, a key is derived from the Firebase key.
WALLET_SECRET=

# --- Stripe (OPTIONAL: leave blank to run in demo mode) ---------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email SMTP (OPTIONAL: leave blank to log emails to console) ------------
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@example.com
