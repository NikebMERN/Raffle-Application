{
  "name": "sf-football-club-raffle",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:api": "pnpm --filter @raffle/api dev",
    "dev:web": "pnpm --filter @raffle/web dev",
    "build": "turbo build",
    "build:frontend": "cd frontend && npm run build",
    "test": "turbo test",
    "test:backend": "cd backend && npm test",
    "seed": "cd backend && npm run seed",
    "db:generate": "pnpm --filter @raffle/api db:generate",
    "db:push": "pnpm --filter @raffle/api db:push",
    "db:seed": "pnpm --filter @raffle/api db:seed",
    "db:studio": "pnpm --filter @raffle/api db:studio"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@10.33.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "esbuild",
      "prisma",
      "sharp"
    ]
  },
  "engines": {
    "node": ">=20"
  }
}
