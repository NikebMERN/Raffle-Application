{
  "hosting": [
    {
      "target": "app",
      "public": "frontend/dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        { "source": "/api/**", "function": "api" },
        { "source": "**", "destination": "/index.html" }
      ]
    },
    {
      "target": "admin",
      "public": "admin/dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        { "source": "/api/**", "function": "api" },
        { "source": "**", "destination": "/index.html" }
      ]
    }
  ],
  "functions": {
    "source": "backend",
    "runtime": "nodejs20",
    "ignore": ["node_modules", ".git", "*.log", "firebase-debug.log", ".env.local", ".env.*.local"]
  }
}
