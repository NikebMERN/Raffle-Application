generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

enum RaffleStatus {
  DRAFT
  ACTIVE
  CLOSED
  DRAWN
  ARCHIVED
}

enum RoundStatus {
  PENDING
  OPEN
  CLOSED
  DRAWN
}

enum TicketStatus {
  ASSIGNED
  SOLD
  UNSOLD
  RETURNED
  CANCELLED
  LOST
  VOIDED
}

enum SaleChannel {
  ONLINE
  OFFLINE
}

enum BookStatus {
  AVAILABLE
  ASSIGNED
  RETURNED
  LOST
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum PermissionAction {
  CREATE
  READ
  UPDATE
  DELETE
  EXPORT
  IMPORT
  BULK_ACTION
  DRAW
  SETTLE
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  email         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  phone         String?
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  roles              UserRole[]
  wallet             Wallet?
  ticketsBought      Ticket[]           @relation("TicketBuyer")
  ticketsSold        Ticket[]           @relation("TicketSeller")
  ticketBooks        TicketBook[]
  sales              Sale[]             @relation("SaleUser")
  salesAsSeller      Sale[]             @relation("SaleSeller")
  payments           Payment[]
  notifications      Notification[]
  auditLogs          AuditLog[]
  activityLogs       ActivityLog[]
  securityLogs       SecurityLog[]
  drawsPerformed     Draw[]             @relation("DrawOperator")
  passwordResetToken PasswordResetToken?

  @@map("users")
}

model Role {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  code        String   @unique
  description String?
  createdAt   DateTime @default(now())

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  module    String
  action    PermissionAction
  createdAt DateTime         @default(now())

  roles RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model UserRole {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  roleId String @db.ObjectId

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String @id @default(auto()) @map("_id") @db.ObjectId
  roleId       String @db.ObjectId
  permissionId String @db.ObjectId

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model PasswordResetToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model Raffle {
  id                String       @id @default(auto()) @map("_id") @db.ObjectId
  title             String
  description       String?
  status            RaffleStatus @default(DRAFT)
  ticketPrice       Float
  maxTicketsPerUser Int          @default(10)
  startDate         DateTime?
  endDate           DateTime?
  imageUrl          String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  rounds             RaffleRound[]
  ticketBooks        TicketBook[]
  tickets            Ticket[]
  rewardConfigurations RewardConfiguration[]

  @@map("raffles")
}

model RaffleRound {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  raffleId    String      @db.ObjectId
  roundNumber Int
  title       String
  drawDate    DateTime?
  status      RoundStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  raffle               Raffle                @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  prizes               Prize[]
  tickets              Ticket[]
  draws                Draw[]
  rewardConfigurations RewardConfiguration[]

  @@unique([raffleId, roundNumber])
  @@map("raffle_rounds")
}

model Prize {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  roundId     String  @db.ObjectId
  name        String
  description String?
  value       Float
  position    Int
  imageUrl    String?

  round RaffleRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  draws Draw[]

  @@map("prizes")
}

/// Admin-controlled reward setup: number of winners and per-person reward amounts
model RewardConfiguration {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  raffleId        String?  @db.ObjectId
  roundId         String?  @db.ObjectId
  numberOfWinners Int
  totalRewardPool Float    @default(0)
  /// [{ position, name, amount, winnersCount, description }]
  rewards         Json
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  raffle Raffle?      @relation(fields: [raffleId], references: [id])
  round  RaffleRound? @relation(fields: [roundId], references: [id])

  @@map("reward_configurations")
}

model TicketBook {
  id                String     @id @default(auto()) @map("_id") @db.ObjectId
  raffleId          String     @db.ObjectId
  bookNumber        String
  sellerId          String?    @db.ObjectId
  startTicketNumber Int
  endTicketNumber   Int
  status            BookStatus @default(AVAILABLE)
  assignedAt        DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  raffle  Raffle  @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  seller  User?   @relation(fields: [sellerId], references: [id])
  tickets Ticket[]

  @@unique([raffleId, bookNumber])
  @@map("ticket_books")
}

model Ticket {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  raffleId     String       @db.ObjectId
  roundId      String?      @db.ObjectId
  bookId       String?      @db.ObjectId
  ticketNumber Int
  status       TicketStatus @default(UNSOLD)
  saleChannel  SaleChannel?
  buyerId      String?      @db.ObjectId
  sellerId     String?      @db.ObjectId
  soldAt       DateTime?
  price        Float?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  raffle Raffle       @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  round  RaffleRound? @relation(fields: [roundId], references: [id])
  book   TicketBook?  @relation(fields: [bookId], references: [id])
  buyer  User?        @relation("TicketBuyer", fields: [buyerId], references: [id])
  seller User?        @relation("TicketSeller", fields: [sellerId], references: [id])
  sale   Sale?
  drawsWon Draw[]

  @@unique([raffleId, ticketNumber])
  @@map("tickets")
}

model Sale {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  ticketId  String      @unique @db.ObjectId
  userId    String?     @db.ObjectId
  sellerId  String?     @db.ObjectId
  channel   SaleChannel
  amount    Float
  paymentId String?     @db.ObjectId
  createdAt DateTime    @default(now())

  ticket  Ticket   @relation(fields: [ticketId], references: [id])
  user    User?    @relation("SaleUser", fields: [userId], references: [id])
  seller  User?    @relation("SaleSeller", fields: [sellerId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])

  @@map("sales")
}

model Draw {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  roundId          String   @db.ObjectId
  prizeId          String   @db.ObjectId
  winnerTicketId   String   @db.ObjectId
  drawnAt          DateTime @default(now())
  drawnById        String   @db.ObjectId
  method           String   @default("CRYPTO_RANDOM")
  participantCount Int

  round        RaffleRound     @relation(fields: [roundId], references: [id])
  prize        Prize           @relation(fields: [prizeId], references: [id])
  winnerTicket Ticket          @relation(fields: [winnerTicketId], references: [id])
  drawnBy      User            @relation("DrawOperator", fields: [drawnById], references: [id])
  auditReport  DrawAuditReport?

  @@map("draws")
}

model DrawAuditReport {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  drawId          String   @unique @db.ObjectId
  participantHash String
  rngMethod       String
  timestamp       DateTime @default(now())
  operatorId      String
  reportJson      Json

  draw Draw @relation(fields: [drawId], references: [id], onDelete: Cascade)

  @@map("draw_audit_reports")
}

model Wallet {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  balance   Float    @default(0)
  currency  String   @default("GBP")
  updatedAt DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id           String          @id @default(auto()) @map("_id") @db.ObjectId
  walletId     String          @db.ObjectId
  type         TransactionType
  amount       Float
  balanceAfter Float
  reference    String?
  description  String?
  createdAt    DateTime        @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("wallet_transactions")
}

model Payment {
  id                    String        @id @default(auto()) @map("_id") @db.ObjectId
  userId                String        @db.ObjectId
  stripeSessionId       String?       @unique
  stripePaymentIntentId String?
  amount                Float
  status                PaymentStatus @default(PENDING)
  metadata              Json?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user  User   @relation(fields: [userId], references: [id])
  sales Sale[]

  @@map("payments")
}

model NotificationTemplate {
  id        String              @id @default(auto()) @map("_id") @db.ObjectId
  name      String              @unique
  channel   NotificationChannel
  subject   String?
  body      String
  variables Json?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  notifications Notification[]

  @@map("notification_templates")
}

model Notification {
  id         String              @id @default(auto()) @map("_id") @db.ObjectId
  userId     String              @db.ObjectId
  templateId String?             @db.ObjectId
  channel    NotificationChannel
  title      String
  body       String
  status     NotificationStatus  @default(PENDING)
  sentAt     DateTime?
  createdAt  DateTime            @default(now())

  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  template NotificationTemplate? @relation(fields: [templateId], references: [id])

  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  action    String
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model ActivityLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  action    String
  details   Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@map("activity_logs")
}

model SecurityLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  event     String
  userId    String?  @db.ObjectId
  ipAddress String?
  userAgent String?
  details   Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@map("security_logs")
}

model SystemSetting {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_settings")
}

model Backup {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  filename  String
  size      Int?
  status    String   @default("COMPLETED")
  createdAt DateTime @default(now())

  @@map("backups")
}

model StripeEvent {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId   String   @unique
  type      String
  processed Boolean  @default(false)
  payload   Json
  createdAt DateTime @default(now())

  @@map("stripe_events")
}
